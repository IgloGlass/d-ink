{
  "name": "d-ink",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run start:local",
    "dev:api": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"$target='http://127.0.0.1:8787'; if (Test-Path '.dev.vars') { $line = Get-Content '.dev.vars' | Where-Object { $_ -match '^DINK_API_PROXY_TARGET=' } | Select-Object -First 1; if ($line) { $target = ($line -split '=',2)[1].Trim() } }; $uri = [System.Uri]$target; $port = if ($uri.IsDefaultPort) { 8787 } else { $uri.Port }; & powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\invoke-local-node-tool.ps1 .\\node_modules\\wrangler\\bin\\wrangler.js dev --port $port\"",
    "dev:web": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\invoke-local-node-tool.ps1 .\\node_modules\\vite\\bin\\vite.js",
    "build:web": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\invoke-local-node-tool.ps1 .\\node_modules\\vite\\bin\\vite.js build",
    "preview:web": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\invoke-local-node-tool.ps1 .\\node_modules\\vite\\bin\\vite.js preview",
    "start:local": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\start-local-dev.ps1",
    "doctor:local": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\check-local-app.ps1",
    "test:local": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\run-local-tests.ps1",
    "generate:tb-template": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\invoke-local-node-tool.ps1 .\\scripts\\generate-trial-balance-template-v1.mjs",
    "typecheck": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\invoke-local-node-tool.ps1 .\\node_modules\\typescript\\bin\\tsc --noEmit",
    "test": "pnpm run test:server && pnpm run test:client",
    "test:runtime-check": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\invoke-local-node-tool.ps1 .\\scripts\\assert-test-runtime.v1.mjs",
    "test:server": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\invoke-local-node-tool.ps1 .\\scripts\\run-server-tests.v1.mjs",
    "test:server:stress": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\invoke-local-node-tool.ps1 .\\scripts\\run-server-tests-stress.v1.mjs",
    "test:client": "pnpm run test:runtime-check && powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\invoke-local-node-tool.ps1 .\\node_modules\\vitest\\vitest.mjs run --config vitest.client.config.ts",
    "test:annual-report:ui": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\invoke-local-node-tool.ps1 .\\scripts\\playwright-annual-report-smoke.v1.mjs",
    "test:annual-report:speed-regression": "pnpm run test:runtime-check && powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\invoke-local-node-tool.ps1 .\\node_modules\\vitest\\vitest.mjs run tests/server/ai/annual-report-speed-regression.v1.test.ts",
    "build:annual-report:speed-regression": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\invoke-local-node-tool.ps1 .\\scripts\\build-annual-report-speed-regression-bundle.v1.mjs",
    "run:annual-report:speed-regression": "pnpm run build:annual-report:speed-regression && powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\invoke-local-node-tool.ps1 .\\output\\annual-report-speed-regression\\run-annual-report-speed-regression.bundle.cjs",
    "test:watch": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\invoke-local-node-tool.ps1 .\\node_modules\\vitest\\vitest.mjs --config vitest.config.ts",
    "lint": "biome check .",
    "lint:logging": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\invoke-local-node-tool.ps1 .\\scripts\\check-tenant-safe-logging.v1.mjs",
    "lint:boundaries": "depcruise --config .dependency-cruiser.cjs --output-type err-long src",
    "format": "biome format --write .",
    "check": "pnpm run lint && pnpm run lint:logging && pnpm run lint:boundaries && pnpm run typecheck && pnpm run test",
    "ralph:frontend:guardrails": "node scripts/ralph/check-design-guardrails.v1.mjs",
    "ralph:frontend:gates": "node scripts/ralph/check-frontend-premium-gates.v1.mjs",
    "ralph:frontend:visual": "node scripts/ralph/run-visual-baseline.v1.mjs",
    "ralph:frontend:smoke": "node scripts/ralph/smoke-loop-tests.v1.mjs",
    "ralph:program": "node scripts/ralph/ralph-program.v1.mjs",
    "ralph:frontend:program": "node scripts/ralph/ralph-frontend-program.v1.mjs --prd scripts/ralph/prd.frontend-full-premium.v1.json --sweeps 6 --max-per-sweep 24 --consecutive-green 2",
    "ralph:frontend:program:strict": "set DINK_RALPH_REQUIRE_VISUAL=1&& node scripts/ralph/ralph-frontend-program.v1.mjs --prd scripts/ralph/prd.frontend-full-premium.v1.json --sweeps 8 --max-per-sweep 8 --consecutive-green 3",
    "ralph:frontend:wave1": "set DINK_RALPH_REQUIRE_VISUAL=1&& node scripts/ralph/ralph-frontend-program.v1.mjs --prd scripts/ralph/prd.frontend-wave1.v1.json --sweeps 8 --max-per-sweep 8 --consecutive-green 3",
    "ralph:frontend:wave2": "set DINK_RALPH_REQUIRE_VISUAL=1&& node scripts/ralph/ralph-frontend-program.v1.mjs --prd scripts/ralph/prd.frontend-wave2.v1.json --sweeps 8 --max-per-sweep 8 --consecutive-green 3",
    "ralph:frontend:wave3": "set DINK_RALPH_REQUIRE_VISUAL=1&& node scripts/ralph/ralph-frontend-program.v1.mjs --prd scripts/ralph/prd.frontend-wave3.v1.json --sweeps 8 --max-per-sweep 8 --consecutive-green 3",
    "ralph:frontend:waves": "pnpm run ralph:frontend:wave1 && pnpm run ralph:frontend:wave2 && pnpm run ralph:frontend:wave3"
  },
  "engines": {
    "node": "^20.12.0 || ^22.0.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.76.1",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "unpdf": "1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/vitest-pool-workers": "^0.8.55",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "dependency-cruiser": "^17.3.8",
    "jsdom": "^26.1.0",
    "playwright": "^1.55.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.8",
    "wrangler": "^4.0.0"
  }
}
