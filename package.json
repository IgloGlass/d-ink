{
  "name": "d-ink",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"corepack pnpm run dev:api\" \"corepack pnpm run dev:web\"",
    "dev:api": "wrangler dev",
    "dev:web": "vite",
    "build:web": "vite build",
    "preview:web": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "corepack pnpm run test:server && corepack pnpm run test:client",
    "test:server": "vitest run --config vitest.config.ts",
    "test:client": "vitest run --config vitest.client.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "corepack pnpm run lint && corepack pnpm run typecheck && corepack pnpm run test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.76.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "@cloudflare/vitest-pool-workers": "^0.8.55",
    "@biomejs/biome": "^1.9.4",
    "concurrently": "^9.1.2",
    "jsdom": "^26.1.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "vite": "^5.4.21",
    "wrangler": "^4.0.0"
  }
}
